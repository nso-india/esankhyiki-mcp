# OpenTelemetry Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Security Configuration (recommended for HTTP deployments)
# =============================================================================

# Authentication mode: required | disabled
# - required: all HTTP requests must include a valid API key
# - disabled: no auth check (local-only development)
MCP_AUTH_MODE=required

# Comma-separated API keys accepted via:
# 1) Authorization: Bearer <key>
# 2) X-API-Key: <key>
MCP_API_KEYS=replace-with-strong-random-key

# Optional: allow initialize handshake without auth (default false)
# MCP_ALLOW_INIT_WITHOUT_AUTH=false

# Optional: per-client rate limit per minute (0 disables)
MCP_RATE_LIMIT_PER_MINUTE=120

# Optional: trusted reverse proxies for forwarding headers
# TRUSTED_PROXY_IPS=127.0.0.1
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16

# =============================================================================
# Telemetry Configuration
# =============================================================================

# Service name shown in traces
OTEL_SERVICE_NAME=mospi-mcp-server

# OTLP collector endpoint (Jaeger, Grafana Tempo, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Protocol: grpc (default) or http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Exporter type: otlp, console, or none
OTEL_TRACES_EXPORTER=otlp

# Safe telemetry defaults (recommended)
TELEMETRY_CAPTURE_TOOL_INPUT=false
TELEMETRY_CAPTURE_TOOL_OUTPUT=false
TELEMETRY_LOG_FULL_OUTPUT=false
TELEMETRY_MAX_ATTR_BYTES=4096

# Optional: additional sensitive keys to redact (comma-separated)
# TELEMETRY_REDACT_KEYS=phone,email,aadhaar

# Optional: Sampling rate (1.0 = 100%, 0.1 = 10%)
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1.0

# Optional: Resource attributes for additional metadata
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development,service.version=1.0.0
